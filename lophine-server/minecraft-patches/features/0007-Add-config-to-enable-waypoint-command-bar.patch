+        this.connections.getAllZ().forEach(WaypointTransmitter.Connection::disconnect); // Lophine - concurrent
+        this.connections.clearAll(); // Lophine - concurrent
     }
 
     public void remakeConnections(WaypointTransmitter waypoint) {
